-- Ayarlar (Config)
local config = { 
    speed = false, 
    proBrake = true, 
    esp = false, 
    noclip = false,
    noFog = false 
}

local function createTgl(txt, pos, key)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, -20, 0, 35)
    b.Position = pos
    b.Text = txt .. ": OFF"
    b.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = Enum.Font.SourceSansBold
    b.Parent = frame
    b.MouseButton1Click:Connect(function()
        config[key] = not config[key]
        b.Text = txt .. (config[key] and ": ON" or ": OFF")
        b.BackgroundColor3 = config[key] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(45, 45, 45)
    end)
end

