-- FİZİKA (Dönmə 0.08 geri alındı)
RunService.Heartbeat:Connect(function()
    if not isAuth then return end
    local char = Players.LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        local seat = char.Humanoid.SeatPart
        if seat and seat:IsA("VehicleSeat") then
            if conf.spd and seat.Throttle == 1 then
                seat.AssemblyLinearVelocity = seat.AssemblyLinearVelocity + (seat.CFrame.LookVector * 1.8)
            end
            if conf.brk and seat.Throttle == -1 then
                local v = seat.CFrame:VectorToObjectSpace(seat.AssemblyLinearVelocity)
                if v.Z < -2 then seat.AssemblyLinearVelocity = seat.AssemblyLinearVelocity * 0.96 end
            end
            if conf.trn and seat.Steer ~= 0 then
                seat.AssemblyAngularVelocity = seat.AssemblyAngularVelocity + Vector3.new(0, -seat.Steer * 0.08, 0)
            end
        end
    end
end)

-- GİZLƏ/AÇ
