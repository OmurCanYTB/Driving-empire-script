-- Ayarlar
local config = { 
    speed = false, 
    extraSoftBrake = true, 
    ultraTurn = true,
    antiFly = true, -- Maşının uçmaması üçün
    esp = false 
}

local function createTgl(txt, pos, key)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, -20, 0, 35)
    b.Position = pos
    b.Text = txt .. ": OFF"
    b.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = Enum.Font.SourceSansBold
    b.Parent = frame
    b.MouseButton1Click:Connect(function()
        config[key] = not config[key]
        b.Text = txt .. (config[key] and ": ON" or ": OFF")
        b.BackgroundColor3 = config[key] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(40, 40, 40)
    end)
end

createTgl("HIZLI SURUS", UDim2.new(0, 10, 0, 50), "speed")
createTgl("YUMSAQ TORMOZ", UDim2.new(0, 10, 0, 100), "extraSoftBrake")
createTgl("MAKSIMUM DONME", UDim2.new(0, 10, 0, 150), "ultraTurn")
createTgl("UCMA ENGELLI", UDim2.new(0, 10, 0, 200), "antiFly")
createTgl("ESP (TEAM)", UDim2.new(0, 10, 0, 250), "esp")

-- Fizika Dövrü
RunService.Stepped:Connect(function()
    local char = Players.LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        local seat = char.Humanoid.SeatPart
        if seat and seat:IsA("VehicleSeat") then
            
            -- Sürət (1.8 Sabit)
            if config.speed and seat.Throttle == 1 then
                seat.AssemblyLinearVelocity = seat.AssemblyLinearVelocity + (seat.CFrame.LookVector * 1.8)
            end
            
            -- EXTRA YUMŞAQ TORMOZ (Daha da zəiflədildi)
            if config.extraSoftBrake and seat.Throttle == -1 then
                -- 0.94-dən 0.97-yə qaldırıldı (Daha uzun məsafədə dayanacaq)
                seat.AssemblyLinearVelocity = seat.AssemblyLinearVelocity * 0.97
                seat.AssemblyAngularVelocity = seat.AssemblyAngularVelocity * 0.97
            end
            
            -- ULTRA DÖNMƏ (Daha güclü sükan dəstəyi)
            if config.ultraTurn and seat.Steer ~= 0 then
                local turnPower = seat.Steer * 0.08 -- 0.05-dən 0.08-ə artırıldı
                seat.AssemblyAngularVelocity = seat.AssemblyAngularVelocity + Vector3.new(0, -turnPower, 0)
            end

            -- ANTİ-FLY / DOWNFORCE (Maşını yerə basır)
            if config.antiFly then
                -- Maşın havaya qalxmağa başlayanda onu aşağı itələyir
                if seat.Position.Y > 5 then 
                    seat.AssemblyLinearVelocity = seat.AssemblyLinearVelocity + Vector3.new(0, -0.5, 0)
                end
            end
        end
    end
end)

-- ESP
RunService.RenderStepped:Connect(function()
    if config.esp then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= Players.LocalPlayer and p.Character then
                if not p.Character:FindFirstChild("OmurESP") then
                    local h = Instance.new("Highlight", p.Character)
                    h.Name = "OmurESP"
                    h.FillColor = (p.Team and p.Team.Name == "Police") and Color3.new(0,0,1) or Color3.new(1,0,0)
                end
            end
        end
    else
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("OmurESP") then
                p.Character.OmurESP:Destroy()
            end
        end
    end
end)

