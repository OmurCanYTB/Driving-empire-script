-- AYARLAR
local config = { speed = false, proBrake = true, easyTurn = true, esp = false, noclip = false }

-- MOD MENU DÜYMƏLƏRİ ÜÇÜN FUNKSİYA
local function addToggle(txt, pos, key)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -30, 0, 40)
    btn.Position = pos
    btn.Text = txt .. ": OFF"
    btn.BackgroundColor3 = Color3.fromRGB(43, 45, 49)
    btn.TextColor3 = Color3.fromRGB(180, 180, 180)
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 14
    btn.Parent = main
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    
    btn.MouseButton1Click:Connect(function()
        config[key] = not config[key]
        if config[key] then
            btn.Text = txt .. ": ON"
            btn.BackgroundColor3 = Color3.fromRGB(35, 165, 89) -- Yaşıl
            btn.TextColor3 = Color3.new(1, 1, 1)
        else
            btn.Text = txt .. ": OFF"
            btn.BackgroundColor3 = Color3.fromRGB(43, 45, 49) -- Boz
            btn.TextColor3 = Color3.fromRGB(180, 180, 180)
        end
    end)
end

