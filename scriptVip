-- AYARLAR
local conf = { spd = false, brk = true, trn = true, stab = true, noclip = false }

local function tgl(txt, key)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, 0, 0, 40)
    b.Text = txt .. ": OFF"
    b.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    b.TextColor3 = Color3.fromRGB(255, 255, 255)
    b.BorderSizePixel = 1
    b.BorderColor3 = Color3.fromRGB(100, 100, 100)
    b.Font = Enum.Font.Gotham
    b.Parent = pPage
    
    b.MouseButton1Click:Connect(function()
        conf[key] = not conf[key]
        b.Text = txt .. (conf[key] and ": ON" or ": OFF")
        b.BackgroundColor3 = conf[key] and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(20, 20, 20)
        b.TextColor3 = conf[key] and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(255, 255, 255)
    end)
end

tgl("HIZLI SURUS", "spd")
tgl("AKILLI TORMOZ", "brk")
tgl("RAHAT DONME", "trn")
tgl("STABILLIK", "stab")
tgl("CAR NOCLIP", "noclip")

