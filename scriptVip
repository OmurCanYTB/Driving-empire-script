-- STATUS DƏYİŞƏNLƏRİ
local state = {
    speed = false,
    boost = false,
    esp = false
}

-- DÜYMƏ YARATMA FUNKSİYASI (VİZUAL ON/OFF İLƏ)
local function createToggle(txt, pos, stateKey, func)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -20, 0, 40)
    btn.Position = pos
    btn.Text = txt .. ": OFF"
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.SourceSansBold
    btn.Parent = frame
    
    btn.MouseButton1Click:Connect(function()
        state[stateKey] = not state[stateKey]
        if state[stateKey] then
            btn.Text = txt .. ": ON"
            btn.BackgroundColor3 = Color3.fromRGB(0, 170, 0) -- Yaşıl
        else
            btn.Text = txt .. ": OFF"
            btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50) -- Boz
        end
        func(state[stateKey])
    end)
end

-- 1. SÜRƏT HACK
createToggle("HIZLI SURUS", UDim2.new(0, 10, 0, 55), "speed", function() end)

-- 2. QALXIŞ BOOST
createToggle("INSTANT ACCEL", UDim2.new(0, 10, 0, 105), "boost", function() end)

-- 3. ESP
createToggle("ESP", UDim2.new(0, 10, 0, 155), "esp", function(val)
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character and p ~= Players.LocalPlayer then
            if val then
                local h = Instance.new("Highlight", p.Character)
                h.Name = "OmurHighlight"
                h.FillColor = (p.Team and p.Team.Name == "Police") and Color3.new(0,0,1) or Color3.new(1,0,0)
            else
                local h = p.Character:FindFirstChild("OmurHighlight")
                if h then h:Destroy() end
            end
        end
    end
end)

