-- AYARLAR
local conf = { eName = false, eBox = false, eLine = false, spd = false, brk = true, trn = true }

local function tgl(txt, par, key)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, -10, 0, 35)
    b.Text = txt .. ": OFF"
    b.Parent = par
    b.MouseButton1Click:Connect(function()
        conf[key] = not conf[key]
        b.Text = txt .. (conf[key] and ": ON" or ": OFF")
        b.BackgroundColor3 = conf[key] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(50, 50, 50)
    end)
end

