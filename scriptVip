-- Fizika və ATM Məntiqi
RunService.Stepped:Connect(function()
    local lp = Players.LocalPlayer
    local char = lp.Character
    if char and char:FindFirstChild("Humanoid") then
        local seat = char.Humanoid.SeatPart
        
        -- MAŞININ İÇİNDƏ ATM "E" MESAFESINI ARTIRMA (EXPERIMENT)
        if config.carReach then
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") then
                    obj.RequiresLineOfSight = false -- Divarın arxasından da görsün
                    obj.MaxActivationDistance = 20 -- Məsafəni artırırıq
                end
            end
        end

        if seat and seat:IsA("VehicleSeat") then
            -- Sürət (1.8 Sabit)
            if config.speed and seat.Throttle == 1 then
                seat.AssemblyLinearVelocity = seat.AssemblyLinearVelocity + (seat.CFrame.LookVector * 1.8)
            end
            
            -- YUMŞAQ TORMOZ (0.98 - Çox səlis)
            if config.softBrake and seat.Throttle == -1 then
                seat.AssemblyLinearVelocity = seat.AssemblyLinearVelocity * 0.98
            end
            
            -- YAĞ KİMİ DÖNMƏ (Artırılmış güc)
            if config.ultraTurn and seat.Steer ~= 0 then
                local turnPower = seat.Steer * 0.12 -- Daha da artırıldı
                seat.AssemblyAngularVelocity = seat.AssemblyAngularVelocity + Vector3.new(0, -turnPower, 0)
            end
        end
    end
end)

-- ESP
RunService.RenderStepped:Connect(function()
    if config.esp then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= Players.LocalPlayer and p.Character then
                if not p.Character:FindFirstChild("OmurESP") then
                    local h = Instance.new("Highlight", p.Character)
                    h.Name = "OmurESP"
                    h.FillColor = (p.Team and p.Team.Name == "Police") and Color3.new(0,0,1) or Color3.new(1,0,0)
                end
            end
        end
    else
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("OmurESP") then
                p.Character.OmurESP:Destroy()
            end
        end
    end
end)

