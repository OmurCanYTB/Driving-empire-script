-- AYARLAR DEYİŞƏNLƏRİ
local conf = { espName = false, espSkeleton = false, espLine = false, spd = false, brk = false }

local function makeToggle(name, parent, key)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, -5, 0, 35)
    b.Text = name .. ": OFF"
    b.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    b.TextColor3 = Color3.fromRGB(255, 255, 255)
    b.Parent = parent
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function()
        conf[key] = not conf[key]
        b.Text = name .. (conf[key] and ": ON" or ": OFF")
        b.BackgroundColor3 = conf[key] and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(25, 25, 25)
        b.TextColor3 = conf[key] and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(255, 255, 255)
    end)
end

local function makeTab(name, pos, page)
    local t = Instance.new("TextButton")
    t.Size = UDim2.new(1, -10, 0, 45)
    t.Position = pos
    t.Text = name
    t.Parent = Tabs
    t.MouseButton1Click:Connect(function() 
        PlayerPage.Visible = false WorldPage.Visible = false ConfigPage.Visible = false 
        page.Visible = true 
    end)
end

