-- ESP SİSTEMİ (SABİT)
local function createESP(plr)
    local limbs = {{"Head", "UpperTorso"}, {"UpperTorso", "LowerTorso"}, {"UpperTorso", "LeftUpperArm"}, {"LeftUpperArm", "LeftLowerArm"}, {"UpperTorso", "RightUpperArm"}, {"RightUpperArm", "RightLowerArm"}, {"LowerTorso", "LeftUpperLeg"}, {"LeftUpperLeg", "LeftLowerLeg"}, {"LowerTorso", "RightUpperLeg"}, {"RightUpperLeg", "RightLowerLeg"}}
    local skelLines = {}
    for i = 1, #limbs do skelLines[i] = Drawing.new("Line") skelLines[i].Thickness = 2 end
    local nameTag = Drawing.new("Text") nameTag.Size = 18 nameTag.Center = true nameTag.Outline = true
    local lineEsp = Drawing.new("Line") lineEsp.Thickness = 1

    RunService.RenderStepped:Connect(function()
        if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr ~= Players.LocalPlayer then
            local char = plr.Character
            local cam = workspace.CurrentCamera
            local rootPos, onScreen = cam:WorldToViewportPoint(char.HumanoidRootPart.Position)
            local rgbColor = Color3.fromHSV(tick() % 3 / 3, 1, 1)
            
            if onScreen then
                if conf.espName then nameTag.Visible = true nameTag.Text = plr.Name nameTag.Position = Vector2.new(rootPos.X, rootPos.Y - 50) nameTag.Color = Color3.new(1, 1, 1) else nameTag.Visible = false end
                if conf.espLine then lineEsp.Visible = true lineEsp.From = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y) lineEsp.To = Vector2.new(rootPos.X, rootPos.Y) lineEsp.Color = Color3.new(1,1,1) else lineEsp.Visible = false end
                if conf.espSkeleton then
                    for i, bone in pairs(limbs) do
                        local pA, pB = char:FindFirstChild(bone[1]), char:FindFirstChild(bone[2])
                        if pA and pB then
                            local posA, onA = cam:WorldToViewportPoint(pA.Position)
                            local posB, onB = cam:WorldToViewportPoint(pB.Position)
                            if onA and onB then skelLines[i].Visible = true skelLines[i].From = Vector2.new(posA.X, posA.Y) skelLines[i].To = Vector2.new(posB.X, posB.Y) skelLines[i].Color = rgbColor else skelLines[i].Visible = false end
                        else skelLines[i].Visible = false end
                    end
                else for i=1, #skelLines do skelLines[i].Visible = false end end
            else nameTag.Visible = false lineEsp.Visible = false for i=1,#skelLines do skelLines[i].Visible = false end end
        else nameTag.Visible = false lineEsp.Visible = false for i=1,#skelLines do skelLines[i].Visible = false end end
    end)
end

for _, p in pairs(Players:GetPlayers()) do createESP(p) end
Players.PlayerAdded:Connect(createESP)

-- SPEED & BRAKE
RunService.Stepped:Connect(function()
    if not isAuth then return end
    local char = Players.LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        local seat = char.Humanoid.SeatPart
        if seat and seat:IsA("VehicleSeat") then
            if conf.spd and seat.Throttle == 1 then seat.AssemblyLinearVelocity = seat.AssemblyLinearVelocity + (seat.CFrame.LookVector * 0.6) end
            if conf.brk and seat.Throttle == -1 then
                local localVel = seat.CFrame:VectorToObjectSpace(seat.AssemblyLinearVelocity)
                if localVel.Z < -1 then seat.AssemblyLinearVelocity = seat.AssemblyLinearVelocity * 0.94 end
            end
        end
    end
end)
